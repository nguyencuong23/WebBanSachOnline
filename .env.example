# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# ── Backend ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Các origin được phép gọi API (phân cách bằng dấu phẩy)
WEB_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Gmail SMTP (dùng cho OTP quên mật khẩu) ───────────────────────────────────
# Hướng dẫn lấy App Password: Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Groq AI (dùng cho chatbot — giữ bí mật, KHÔNG dùng NEXT_PUBLIC_) ──────────
# Lấy miễn phí tại: https://console.groq.com
# Model: llama-3.3-70b-versatile (thông minh, không giới hạn requests)
GROQ_API_KEY=gsk_xxx

# ── Frontend (NEXT_PUBLIC_*) ───────────────────────────────────────────────────
# Bypass key để vào trang /auth khi đang bật chế độ bảo trì
NEXT_PUBLIC_MAINTENANCE_BYPASS_KEY=your_secret_bypass_key
