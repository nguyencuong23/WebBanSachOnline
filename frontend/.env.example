# ── API Backend ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
# ── Google Gemini AI Chatbot ──────────────────────────────────────────────────
# Không khai báo API key ở Frontend để bảo mật. Khóa GEMINI_API_KEY được cấu hình ở file .env của Backend.

# ── Maintenance Mode ──────────────────────────────────────────────────────────
# Key bí mật để admin vào /auth?bypass=<key> khi web đang bảo trì
NEXT_PUBLIC_MAINTENANCE_BYPASS_KEY=your_secret_bypass_key
