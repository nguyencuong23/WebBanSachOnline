{
  "name": "webbansachonline",
  "private": true,
  "description": "Gói gốc: script npm gọi Docker Compose (API + Web)",
  "scripts": {
    "docker:dev": "docker compose -f docker-compose.dev.yml up",
    "docker:dev:build": "docker compose -f docker-compose.dev.yml up --build",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:prod:build": "docker compose -f docker-compose.yml build",
    "docker:prod:up": "docker compose -f docker-compose.yml up -d",
    "docker:prod:build:up": "docker compose -f docker-compose.yml up -d --build",
    "docker:prod:down": "docker compose -f docker-compose.yml down",
    "docker:prod:logs": "docker compose -f docker-compose.yml logs -f"
  }
}
